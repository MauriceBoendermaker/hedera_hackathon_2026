durl.dev {
    # Analytics/redirect server handles API routes and short links
    handle /s/* {
        reverse_proxy localhost:5001
    }
    handle /hcs/* {
        reverse_proxy localhost:5001
    }
    handle /auth/* {
        reverse_proxy localhost:5001
    }
    handle /analytics/* {
        reverse_proxy localhost:5001
    }
    handle /stats* {
        reverse_proxy localhost:5001
    }
    handle /track* {
        reverse_proxy localhost:5001
    }
    handle /privacy* {
        reverse_proxy localhost:5001
    }
    handle /feedback* {
        reverse_proxy localhost:5001
    }
    handle /health {
        reverse_proxy localhost:5001
    }
    handle /admin/* {
        reverse_proxy localhost:5001
    }

    # React frontend serves everything else
    handle {
        reverse_proxy localhost:5000
    }
}
